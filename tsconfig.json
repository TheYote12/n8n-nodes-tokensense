{
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "./dist",
		"rootDir": ".",
		"declaration": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"sourceMap": true
	},
	"include": [
		"credentials/**/*.ts",
		"nodes/**/*.ts",
		"shared/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"test",
		"future"
	]
}
