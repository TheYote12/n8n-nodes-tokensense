			"dist/nodes/TokenSenseAi/TokenSenseAi.node.js",
			"dist/nodes/TokenSenseChatModel/TokenSenseChatModel.node.js"
		],
		"credentials": [
			"dist/credentials/TokenSenseApi.credentials.js"
		]
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@langchain/openai": "^0.5.13",
		"form-data": "^4.0.2"
	},
	"peerDependencies": {
		"n8n-workflow": ">=1.0.0"
	},
	"overrides": {
		"langsmith": "^0.5.16"
	},
	"devDependencies": {
		"@n8n/ai-node-sdk": "^0.7.0",
		"@n8n/eslint-plugin-community-nodes": "^0.10.0",
		"@n8n/node-cli": "^0.23.1",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.19.17",
		"@typescript-eslint/parser": "^8.58.2",
		"eslint": "^9.39.4",
		"eslint-plugin-n8n-nodes-base": "^1.16.6",
		"jest": "^29.7.0",
		"n8n-workflow": "^2.13.1",
		"ts-jest": "^29.4.9",
		"typescript": "^5.7.3"
	}
